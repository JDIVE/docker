# Home Assistant .gitignore

# Exclude database files
config/*.db
config/*.db-*

# Exclude log files
config/*.log
config/*.log.*

# Exclude sensitive data directories
config/.storage/
config/.cloud/
config/deps/
config/tts/
config/www/community/
config/image/

# Exclude other runtime files
config/OZW_Log.txt
config/.HA_VERSION

# Include
# config/configuration.yaml
# config/automations.yaml
# config/scripts.yaml
# config/scenes.yaml
# config/ui-lovelace.yaml (if exists)
# config/themes/ (if exists)
# config/blueprints/ (if you have custom blueprints) 