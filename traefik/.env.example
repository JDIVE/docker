# Traefik Configuration
TRAEFIK_DASHBOARD_AUTH=admin:your_hashed_password_here
TRAEFIK_ACME_EMAIL=your.email@example.com
TRAEFIK_LOG_PATH=/var/log/traefik/access.log

# Cloudflare DNS API Credentials
CF_API_EMAIL=your.email@example.com
CF_DNS_API_TOKEN=your_cloudflare_api_token_here

# Domains
DOMAIN_TRAEFIK=traefik.yourdomain.com
DOMAIN_GITLAB=gitlab.yourdomain.com
DOMAIN_TRUENAS=truenas.yourdomain.com
DOMAIN_PROXMOX=proxmox.yourdomain.com
DOMAIN_UNIFI=unifi.yourdomain.com
DOMAIN_HOMEPAGE=homepage.yourdomain.com
DOMAIN_OLLAMA=ollama.yourdomain.com

# Backend Service IPs
TRUENAS_IP=10.0.0.1
PROXMOX_IP=10.0.0.2
UNIFI_IP=10.0.0.3

# Backend Service Ports
TRUENAS_PORT=443
PROXMOX_PORT=8006
UNIFI_PORT=8443
